    ],
  },
]

const ROUTE_LABELS: Record<string, string> = {
  '/patio':         'Pátio',
  '/ordens':        'Ordens de Serviço',
  '/agendamento':   'Agendamento',
  '/clientes':      'Clientes',
  '/financeiro':    'Financeiro',
  '/estoque':       'Estoque',
  '/equipe':        'Equipe',
  '/configuracoes': 'Configurações',
}

// ── Mudança 2: itens da bottom nav ───────────────────────────────

const BOTTOM_NAV: NavItem[] = [
