            {/* Serviços */}
            <section className="space-y-3">
              <p className="flex items-center gap-1.5 text-[11px] font-semibold text-gray-500 uppercase tracking-wider">
                <Wrench size={12} /> Serviços<span className="text-accent">*</span>
