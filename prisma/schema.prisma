// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StatusCliente {
  ativo
  inativo
}

enum StatusOS {
  em_andamento
  aguardando_material
  aguardando_aprovacao
  concluido
  cancelado
}

enum StatusPagamento {
  pago
  a_receber
}

enum Role {
  OWNER
  MANAGER
  OPERATOR
}

model Loja {
  id        String   @id @default(uuid())
  nome      String
  plano     String
  createdAt DateTime @default(now())

  usuarios Usuario[]
  clientes Cliente[]
  veiculos Veiculo[]
  ordens   OrdemServico[]

  @@map("lojas")
}

model Usuario {
  id          String   @id @default(uuid())
  authUserId  String   @unique // uuid de auth.users (Supabase) — sem FK, fora do schema do Prisma
  nome        String
  email       String
  role        Role
  lojaId      String
  createdAt   DateTime @default(now())

  loja        Loja     @relation(fields: [lojaId], references: [id])

  @@index([lojaId])
  @@map("usuarios")
}

model Cliente {
  id           String        @id @default(uuid())
  userId       String        @default("default-user-id")
  lojaId       String
  nome         String
  telefone     String
  email        String
  cpf          String
  comoConheceu String
  dataCadastro DateTime      @default(now())
  totalGasto   Float         @default(0)
  cidade       String?
  status       StatusCliente @default(ativo)

  loja     Loja           @relation(fields: [lojaId], references: [id])
  veiculos Veiculo[]
  ordens   OrdemServico[]

  @@index([userId])
  @@index([lojaId])
  @@map("clientes")
}

model Veiculo {
  id        String @id @default(uuid())
  userId    String @default("default-user-id")
  lojaId    String
  clienteId String
  marca     String
  modelo    String
  ano       Int
  cor       String
  placa     String

  loja    Loja           @relation(fields: [lojaId], references: [id])
  cliente Cliente        @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  ordens  OrdemServico[]

  @@index([userId])
  @@index([lojaId])
  @@map("veiculos")
}

model OrdemServico {
  id                String           @id @default(uuid())
  userId            String           @default("default-user-id")
  lojaId            String
  numero            Int              @unique @default(autoincrement())
  clienteId         String
  veiculoId         String
  servicos          Json // Array de ItemOS: { servicoId, nome, preco }
  valorTotal        Float
  formaPagamento    String
  instaladorId      String
  box               Int
  comissao          Float
  observacoes       String
  status            StatusOS         @default(aguardando_aprovacao)
  statusPagamento   StatusPagamento?
  dataCriacao       DateTime         @default(now())
  dataFinalizacao   DateTime?
  dataSaidaPrevista DateTime?
  agendamentoId     String?
  materiaisUsados   Json? // Array de MaterialUsado
  entregue          Boolean?         @default(false)
  dataSaida         DateTime?

  loja    Loja    @relation(fields: [lojaId], references: [id])
  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  veiculo Veiculo @relation(fields: [veiculoId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([lojaId])
  @@map("ordens_servico")
}
