// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StatusCliente {
  ativo
  inativo
}

enum StatusOS {
  em_andamento
  aguardando_material
  aguardando_aprovacao
  concluido
  cancelado
}

enum StatusPagamento {
  pago
  a_receber
}

enum Role {
  OWNER
  MANAGER
  OPERATOR
}

enum StatusAgendamento {
  agendado
  confirmado
  concluido
  cancelado
}

enum StatusGarantia {
  ativa
  acionada
  expirada
}

enum TipoLancamento {
  entrada
  saida
}

model Loja {
  id        String   @id @default(uuid())
  nome      String
  plano     String
  createdAt DateTime @default(now())

  usuarios      Usuario[]
  clientes      Cliente[]
  veiculos      Veiculo[]
  ordens        OrdemServico[]
  agendamentos  Agendamento[]
  instaladores  Instalador[]
  lancamentos   LancamentoFinanceiro[]
  produtos      Produto[]
  garantias     Garantia[]
  metas         Meta[]
  configuracoes Configuracoes?
  servicos      Servico[]

  @@map("lojas")
}

model Usuario {
  id          String   @id @default(uuid())
  authUserId  String   @unique // uuid de auth.users (Supabase) — sem FK, fora do schema do Prisma
  nome        String
  email       String
  role        Role
  lojaId      String
  createdAt   DateTime @default(now())

  loja        Loja     @relation(fields: [lojaId], references: [id])

  @@index([lojaId])
  @@map("usuarios")
}

model Cliente {
  id           String        @default(uuid())
  lojaId       String
  nome         String
  telefone     String
  email        String
  cpf          String
  comoConheceu String
  dataCadastro DateTime      @default(now())
  totalGasto   Float         @default(0)
  cidade       String?
  status       StatusCliente @default(ativo)

  loja     Loja           @relation(fields: [lojaId], references: [id])
  veiculos Veiculo[]
  ordens   OrdemServico[]

  // Chave composta (lojaId, id) — não apenas @id em "id" — porque "id" sozinho
  // não é globalmente único entre lojas: ids curtos e fixos como os do dado
  // de demonstração (c1..c10) se repetem em toda loja nova que nunca editou
  // o exemplo, e "id" isolado como PRIMARY KEY rejeitava a segunda loja que
  // tentasse ter um cliente "c1". Ver CLAUDE.md, "Migração de entidades pro
  // Supabase" — mesmo ajuste precisa ser replicado em toda entidade migrada
  // daqui pra frente. @@index([lojaId]) foi removido por ser redundante: o
  // índice da PK composta já cobre buscas por lojaId sozinho (prefixo mais à
  // esquerda de um índice B-tree).
  @@id([lojaId, id])
  @@map("clientes")
}

model Veiculo {
  id        String @default(uuid())
  lojaId    String
  clienteId String
  marca     String
  modelo    String
  ano       Int
  cor       String
  placa     String

  loja Loja @relation(fields: [lojaId], references: [id])
  // FK composta (lojaId, clienteId) → clientes(lojaId, id): garante, no nível
  // do banco, que um veículo só pode apontar pra um cliente da MESMA loja —
  // não só corrige a colisão de id entre lojas, como fecha uma lacuna de
  // integridade cross-tenant que existia mesmo antes (nada impedia hoje um
  // clienteId de uma loja ser gravado, por engano, apontando pra outra).
  cliente Cliente        @relation(fields: [lojaId, clienteId], references: [lojaId, id], onDelete: Cascade)
  ordens  OrdemServico[]

  // Chave composta (lojaId, id) — mesmo motivo e mesmo padrão de Cliente (ver
  // comentário lá): initialVeiculos usa ids curtos fixos (v1..v10), únicos só
  // dentro do namespace local de cada loja, que colidiriam em "id" como PK
  // global assim que uma segunda loja migrasse seus veículos locais pro
  // Supabase. @@index([lojaId]) removido por ser redundante: o índice da PK
  // composta já cobre buscas por lojaId sozinho (prefixo mais à esquerda).
  @@id([lojaId, id])
  @@map("veiculos")
}

model OrdemServico {
  id                String           @default(uuid())
  lojaId            String
  numero            Int              @unique @default(autoincrement())
  clienteId         String
  veiculoId         String
  servicos          Json // Array de ItemOS: { servicoId, nome, preco }
  valorTotal        Float
  formaPagamento    String
  instaladorId      String
  box               Int
  comissao          Float
  observacoes       String
  status            StatusOS         @default(aguardando_aprovacao)
  statusPagamento   StatusPagamento?
  dataCriacao       DateTime         @default(now())
  dataFinalizacao   DateTime?
  dataSaidaPrevista DateTime?
  agendamentoId     String?
  materiaisUsados   Json? // Array de MaterialUsado
  entregue          Boolean?         @default(false)
  dataSaida         DateTime?

  loja Loja @relation(fields: [lojaId], references: [id])
  // Mesma FK composta que Veiculo.cliente — ver comentário lá.
  cliente Cliente @relation(fields: [lojaId, clienteId], references: [lojaId, id], onDelete: Restrict)
  // Idem, agora que Veiculo também tem PK composta (lojaId, id).
  veiculo Veiculo @relation(fields: [lojaId, veiculoId], references: [lojaId, id], onDelete: Restrict)

  // Chave composta (lojaId, id) — mesmo motivo e mesmo padrão de Cliente/Veiculo
  // (ver comentários lá): terceira entidade migrada pro Supabase, terceira a
  // precisar do mesmo tratamento. @@index([lojaId]) removido por ser
  // redundante: o índice da PK composta já cobre buscas por lojaId sozinho.
  @@id([lojaId, id])
  @@map("ordens_servico")
}

model Agendamento {
  id             String            @id @default(uuid())
  lojaId         String
  clienteId      String
  veiculoId      String
  servicoId      String
  instaladorId   String
  box            Int
  data           DateTime
  horario        String
  duracao        Int
  status         StatusAgendamento @default(agendado)
  valor          Float?
  reagendamentos Int?

  loja Loja @relation(fields: [lojaId], references: [id])

  @@index([lojaId])
  @@map("agendamentos")
}

model Instalador {
  id             String   @id @default(uuid())
  lojaId         String
  nome           String
  especialidades String[]
  comissaoPadrao Float
  ativo          Boolean  @default(true)

  loja Loja @relation(fields: [lojaId], references: [id])

  @@index([lojaId])
  @@map("instaladores")
}

model LancamentoFinanceiro {
  id             String         @default(uuid())
  lojaId         String
  tipo           TipoLancamento
  categoria      String
  descricao      String
  valor          Float
  data           DateTime
  formaPagamento String
  osId           String?

  loja Loja @relation(fields: [lojaId], references: [id])

  // Chave composta (lojaId, id) — mesmo motivo e mesmo padrão de
  // Cliente/Veiculo/OrdemServico (ver comentário em Cliente): quinta entidade
  // migrada pro Supabase. osId é uma referência solta (String?, sem FK) pro
  // id de OrdemServico — nenhuma FK composta a criar aqui, só a PK.
  // @@index([lojaId]) removido por ser redundante: o índice da PK composta
  // já cobre buscas por lojaId sozinho.
  @@id([lojaId, id])
  @@map("lancamentos_financeiro")
}

model Produto {
  id            String @default(uuid())
  lojaId        String
  nome          String
  sku           String
  categoria     String
  fornecedor    String
  quantidade    Int
  minimo        Int
  unidade       String
  valorUnitario Float

  loja Loja @relation(fields: [lojaId], references: [id])

  // Chave composta (lojaId, id) — mesmo motivo e mesmo padrão de
  // Cliente/Veiculo/OrdemServico (ver comentário em Cliente): quarta entidade
  // migrada pro Supabase. @@index([lojaId]) removido por ser redundante: o
  // índice da PK composta já cobre buscas por lojaId sozinho.
  @@id([lojaId, id])
  @@map("produtos")
}

model Garantia {
  id         String         @id @default(uuid())
  lojaId     String
  osId       String
  clienteId  String
  veiculoId  String
  servico    String
  produto    String
  dataInicio DateTime
  dataFim    DateTime
  status     StatusGarantia @default(ativa)

  loja Loja @relation(fields: [lojaId], references: [id])

  @@index([lojaId])
  @@map("garantias")
}

model Meta {
  id            String @id @default(uuid())
  lojaId        String
  mes           Int
  ano           Int
  faturamento   Float
  numeroOS      Int
  ticketMedio   Float
  novosClientes Int

  loja Loja @relation(fields: [lojaId], references: [id])

  @@index([lojaId])
  @@map("metas")
}

model Configuracoes {
  id             String   @id @default(uuid())
  lojaId         String   @unique
  nomeLoja       String
  cidade         String
  telefone       String
  email          String
  corPrimaria    String
  numeroBoxes    Int
  comissaoPadrao Float
  notifEstoque   Boolean? @default(true)
  notifGarantia  Boolean? @default(true)
  notifPosVenda  Boolean? @default(true)

  loja Loja @relation(fields: [lojaId], references: [id])

  @@map("configuracoes")
}

model Servico {
  id           String @id @default(uuid())
  lojaId       String
  nome         String
  preco        Float?
  tempEstimado Int?
  duracaoDias  Int?

  loja Loja @relation(fields: [lojaId], references: [id])

  @@index([lojaId])
  @@map("servicos")
}
